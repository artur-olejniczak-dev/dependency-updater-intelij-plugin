<idea-plugin>
    <id>pl.artoledev.dependencyupdater</id>
    <name>DependencyUpdater</name>
    <vendor email="artur.olejniczak.dev@gmail.com" > Artur Olejniczak</vendor>

    <description><![CDATA[
      An IntelliJ IDEA plugin for managing dependencies and identifying security vulnerabilities.
      It scans your Maven and Gradle project files, discovers newer library versions, filters Long Term Support (LTS) releases,
      and connects to the OSV API to expose Common Vulnerabilities and Exposures (CVE) in both direct and transitive dependencies.
    ]]></description>

    <!-- Dependencies on other plugins (to access Maven and Java PSI structures) -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>org.jetbrains.idea.maven</depends>
    <depends>org.jetbrains.plugins.gradle</depends>

    <!-- Extension declarations (Tool windows, actions, services) -->
    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="com.example.dependencyupdater.settings.DependencyUpdaterSettingsState"/>
        <applicationConfigurable parentId="tools" instance="com.example.dependencyupdater.settings.DependencyUpdaterSettingsConfigurable" id="com.example.dependencyupdater.settings.DependencyUpdaterSettingsConfigurable" displayName="Dependency Updater"/>
        
        <!-- Registering our Tool Window -->
        <toolWindow id="Dependency Updater" 
                    secondary="true" 
                    anchor="bottom" 
                    icon="AllIcons.General.Warning"
                    factoryClass="com.example.dependencyupdater.DependencyUpdaterToolWindowFactory"/>
    </extensions>

    <actions>
        <!-- Top menu actions can be added here in the future -->
    </actions>
</idea-plugin>
